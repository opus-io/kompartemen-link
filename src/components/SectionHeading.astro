---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="mb-[24px] text-center">
  <div class="flex items-center gap-[12px] justify-center mb-[8px]">
    <div class="h-[1px] flex-1 max-w-[40px] bg-[#C8C4BC]"></div>
    <h3 class="text-[11px] font-sans text-[#8A8680] uppercase tracking-[0.2em] leading-none">
      {title}
    </h3>
    <div class="h-[1px] flex-1 max-w-[40px] bg-[#C8C4BC]"></div>
  </div>
</div>
