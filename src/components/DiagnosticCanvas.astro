---
let diagnosticLines = [
  "Ruang yang tertata.",
  "Sistem yang bekerja.",
  "Pikiran yang lega.",
];
let diagnosticTags = [
  "PILIHAN // TERKURASI",
  "RUTIN // TERJADWAL",
  "SISTEM // AKTIF",
];
try {
  const config = await import("../../content/config.json", { assert: { type: "json" } });
  const cfg = config.default || config;
  if (cfg.diagnosticLines) diagnosticLines = cfg.diagnosticLines;
  if (cfg.diagnosticTags) diagnosticTags = cfg.diagnosticTags;
} catch {}

const linesJson = JSON.stringify(diagnosticLines);
const tagsJson = JSON.stringify(diagnosticTags);
---

<div
  class="w-full overflow-hidden relative"
  style="background-color: #EDE8DF; border-bottom: 1px solid #C8C4BC; padding: 48px 24px;"
  data-lines={linesJson}
  data-tags={tagsJson}
>
  <div class="max-w-[680px] mx-auto text-center">
    <div class="font-display text-[15px] text-[#8A8680] tracking-[0.12em] uppercase mb-[12px]">
      [ <span id="diagTag" data-tags={tagsJson}>PILIHAN // TERKURASI</span> ]
    </div>
    <p
      id="diagLine"
      class="font-display text-[24px] md:text-[32px] text-[#2E2B27] leading-[1.3] italic"
    >
      Ruang yang tertata.
    </p>
    <div class="section-sep max-w-[60px] mx-auto mt-[24px]"></div>
  </div>
</div>

<script>
  function initQuietCanvas() {
    var container = document.querySelector('[data-lines]');
    if (!container) return;
    var lines = JSON.parse(container.getAttribute('data-lines'));
    var tags = JSON.parse(container.getAttribute('data-tags'));
    if (!lines.length) lines = ["Ruang yang tertata.", "Sistem yang bekerja.", "Pikiran yang lega."];
    if (!tags.length) tags = ["PILIHAN // TERKURASI", "RUTIN // TERJADWAL", "SISTEM // AKTIF"];

    var lineEl = document.getElementById('diagLine');
    var tagEl = document.getElementById('diagTag');
    if (!lineEl || !tagEl) return;

    var idx = 0;
    var lineIdx = 0;
    var charIdx = 0;
    var isDeleting = false;
    var timer = 0;
    var holding = false;

    function tick() {
      // Fade between tags every few seconds
      tagEl.style.opacity = '0.4';
      setTimeout(function() {
        tagEl.textContent = tags[idx];
        tagEl.style.opacity = '';
      }, 200);

      idx = (idx + 1) % tags.length;
      setTimeout(tick, 5000);
    }

    tick();

    // Subtle typewriter for the line text
    var fullText = lines[0];
    lineEl.textContent = '';
    var ci = 0;

    function typeLine() {
      if (ci < fullText.length) {
        lineEl.textContent += fullText[ci];
        ci++;
        setTimeout(typeLine, 50 + Math.random() * 40);
      } else {
        lineEl.style.opacity = '1';
        setTimeout(function() {
          // Hold then switch
          ci = 0;
          lineEl.style.opacity = '0.3';
          lineEl.style.transform = 'translateY(4px)';
          setTimeout(function() {
            lineEl.textContent = '';
            lineEl.style.opacity = '';
            lineEl.style.transform = '';
            lineIdx = (lineIdx + 1) % lines.length;
            fullText = lines[lineIdx];
            typeLine();
          }, 400);
        }, 3500);
      }
    }

    typeLine();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initQuietCanvas);
  } else {
    initQuietCanvas();
  }
</script>
