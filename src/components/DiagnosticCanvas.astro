---
let diagnosticLines = [
  "Ruang yang tertata.",
];
let diagnosticTags = [
  "PILIHAN // TERKURASI",
];
try {
  const config = await import("../../content/config.json", { assert: { type: "json" } });
  const cfg = config.default || config;
  if (cfg.diagnosticLines) diagnosticLines = cfg.diagnosticLines;
  if (cfg.diagnosticTags) diagnosticTags = cfg.diagnosticTags;
} catch {}

const linesJson = JSON.stringify(diagnosticLines);
const tagsJson = JSON.stringify(diagnosticTags);
---

<div
  class="absolute top-0 left-0 w-full h-[34vh] z-0 overflow-hidden"
  style="background-color: #EDE8DF; border-bottom: 1px solid #C8C4BC;"
  aria-hidden="true"
  data-lines={linesJson}
  data-tags={tagsJson}
>
  <div
    class="absolute inset-0 flex flex-col items-center justify-center px-[24px]"
  >
    <div class="font-sans text-[12px] text-[#8A8680] tracking-[0.15em] uppercase mb-[16px] opacity-0" id="diagTag">
      PILIHAN // TERKURASI
    </div>
    <p
      id="diagLine"
      class="font-display text-[24px] md:text-[30px] text-[#5A5650] leading-[1.25] italic text-center opacity-0"
      style="transform: translateY(8px);"
    >
      Ruang yang tertata.
    </p>
    <div class="w-[40px] h-[1px] bg-[#C8C4BC] mt-[20px] opacity-0" id="diagLineDivider"></div>
  </div>
  <div
    class="absolute bottom-0 left-0 w-full h-[60%] pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #F5F0E8);"
    aria-hidden="true"
  >
  </div>
</div>

<script>
  function init() {
    var tagEl = document.getElementById('diagTag');
    var lineEl = document.getElementById('diagLine');
    var dividerEl = document.getElementById('diagLineDivider');
    if (!lineEl || !tagEl) return;

    // Gentle fade-in sequence
    setTimeout(function() {
      tagEl.style.transition = 'opacity 0.8s ease';
      tagEl.style.opacity = '1';
    }, 300);

    setTimeout(function() {
      lineEl.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      lineEl.style.opacity = '1';
      lineEl.style.transform = 'translateY(0)';
    }, 600);

    if (dividerEl) {
      setTimeout(function() {
        dividerEl.style.transition = 'opacity 0.8s ease';
        dividerEl.style.opacity = '1';
      }, 900);
    }

    // Cycle tags quietly
    var container = document.querySelector('[data-tags]');
    if (container) {
      var tags = JSON.parse(container.getAttribute('data-tags'));
      if (tags && tags.length > 1) {
        var idx = 0;
        setInterval(function() {
          idx = (idx + 1) % tags.length;
          tagEl.style.opacity = '0';
          setTimeout(function() {
            tagEl.textContent = tags[idx];
            tagEl.style.opacity = '1';
          }, 400);
        }, 5000);
      }
    }
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
