---
let diagnosticLines = [
  "Ruang yang tertata.",
  "Sistem yang bekerja.",
  "Pikiran yang lega.",
];
let diagnosticTags = [
  "PILIHAN // TERKURASI",
  "RUTIN // TERJADWAL",
  "SISTEM // AKTIF",
];
try {
  const config = await import("../../content/config.json", { assert: { type: "json" } });
  const cfg = config.default || config;
  if (cfg.diagnosticLines) diagnosticLines = cfg.diagnosticLines;
  if (cfg.diagnosticTags) diagnosticTags = cfg.diagnosticTags;
} catch {}

const linesJson = JSON.stringify(diagnosticLines);
const tagsJson = JSON.stringify(diagnosticTags);
---

<div
  class="absolute top-0 left-0 w-full h-[34vh] z-0 overflow-hidden"
  style="background-color: #EDE8DF; border-bottom: 1px solid #C8C4BC;"
  aria-hidden="true"
  data-lines={linesJson}
  data-tags={tagsJson}
>
  <div
    class="absolute inset-0 flex flex-col items-center justify-center px-[24px]"
  >
    <div class="font-display text-[13px] text-[#8A8680] tracking-[0.12em] uppercase mb-[12px]">
      [ <span id="diagTag">PILIHAN // TERKURASI</span> ]
    </div>
    <p
      id="diagLine"
      class="font-display text-[22px] md:text-[28px] text-[#2E2B27] leading-[1.3] italic text-center"
    >
      Ruang yang tertata.
    </p>
  </div>
  <div
    class="absolute bottom-0 left-0 w-full h-[60%] pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #F5F0E8);"
    aria-hidden="true"
  >
  </div>
</div>

<script>
  function initCanvas() {
    var container = document.querySelector('[data-lines]');
    if (!container) return;
    var lines = JSON.parse(container.getAttribute('data-lines'));
    var tags = JSON.parse(container.getAttribute('data-tags'));
    if (!lines.length) lines = ["Ruang yang tertata.", "Sistem yang bekerja.", "Pikiran yang lega."];
    if (!tags.length) tags = ["PILIHAN // TERKURASI", "RUTIN // TERJADWAL", "SISTEM // AKTIF"];

    var lineEl = document.getElementById('diagLine');
    var tagEl = document.getElementById('diagTag');
    if (!lineEl || !tagEl) return;

    var tagIdx = 0;
    var lineIdx = 0;
    var ci = 0;
    var fullText = lines[0];
    lineEl.textContent = '';

    function cycleTags() {
      tagEl.style.opacity = '0.4';
      setTimeout(function() {
        tagEl.textContent = tags[tagIdx];
        tagEl.style.opacity = '';
      }, 200);
      tagIdx = (tagIdx + 1) % tags.length;
      setTimeout(cycleTags, 5000);
    }
    cycleTags();

    function typeLine() {
      if (ci < fullText.length) {
        lineEl.textContent += fullText[ci];
        ci++;
        setTimeout(typeLine, 50 + Math.random() * 40);
      } else {
        lineEl.style.opacity = '1';
        setTimeout(function() {
          ci = 0;
          lineEl.style.opacity = '0.3';
          lineEl.style.transform = 'translateY(4px)';
          setTimeout(function() {
            lineEl.textContent = '';
            lineEl.style.opacity = '';
            lineEl.style.transform = '';
            lineIdx = (lineIdx + 1) % lines.length;
            fullText = lines[lineIdx];
            typeLine();
          }, 400);
        }, 3500);
      }
    }
    typeLine();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCanvas);
  } else {
    initCanvas();
  }
</script>
